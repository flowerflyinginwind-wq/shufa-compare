{
  "name": "shufa-compare",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "node -e \"const fs=require('fs'); if(!fs.existsSync('node_modules/vite')){console.log('正在安装依赖...'); require('child_process').execSync('npm install',{stdio:'inherit'})}\"",
    "dev": "npx vite",
    "dev:mobile": "npx vite --host",
    "build": "tsc -b && npx vite build",
    "preview": "npx vite preview --host",
    "test": "node scripts/run-tests.mjs",
    "test:unit": "vitest run",
    "test:all": "powershell -ExecutionPolicy Bypass -File scripts/auto-test.ps1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^3.2.4",
    "happy-dom": "^17.4.7"
  }
}
